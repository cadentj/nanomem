{
    "name": "@openanonymity/nanomem",
    "version": "0.1.2",
    "description": "LLM-driven personal memory with agentic retrieval, extraction, and compaction",
    "type": "module",
    "bin": {
        "nanomem": "src/cli.js"
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/openanonymity/nanomem.git"
    },
    "bugs": {
        "url": "https://github.com/openanonymity/nanomem/issues"
    },
    "scripts": {
        "test": "node --test test/**/*.test.js",
        "prepublishOnly": "npm run build:types",
        "build:types": "tsc",
        "prepack": "tsc"
    },
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "default": "./src/index.js"
        },
        "./format": {
            "types": "./types/internal/format/index.d.ts",
            "default": "./src/internal/format/index.js"
        },
        "./storage": {
            "types": "./types/internal/storage/BaseStorage.d.ts",
            "default": "./src/internal/storage/BaseStorage.js"
        },
        "./utils": {
            "types": "./types/internal/portability.d.ts",
            "default": "./src/internal/portability.js"
        },
        "./imports": {
            "types": "./types/internal/imports/index.d.ts",
            "default": "./src/internal/imports/index.js"
        },
        "./llm": {
            "types": "./types/internal/llm-client/openai.d.ts",
            "default": "./src/internal/llm-client/openai.js"
        },
        "./llm/openai": {
            "types": "./types/internal/llm-client/openai.d.ts",
            "default": "./src/internal/llm-client/openai.js"
        },
        "./llm/anthropic": {
            "types": "./types/internal/llm-client/anthropic.d.ts",
            "default": "./src/internal/llm-client/anthropic.js"
        }
    },
    "types": "./types/index.d.ts",
    "main": "./src/index.js",
    "files": [
        "src/",
        "types/"
    ],
    "keywords": [
        "memory",
        "llm",
        "ai",
        "personal-memory",
        "retrieval",
        "extraction"
    ],
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^25.5.2",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "@pierre/diffs": "^1.1.12",
        "tinfoil": "^1.1.3"
    },
    "directories": {
        "doc": "docs"
    },
    "author": "openanonymity",
    "homepage": "https://github.com/openanonymity/nanomem#readme"
}
